# Copy to .env and edit. Auto-loaded by config.py; shell exports override these.
# Only uncomment what you want to change — everything has a sane default.

# --- Model -------------------------------------------------------------------
# ASSISTANT_MODEL=gemma4:e2b
# OLLAMA_URL=http://localhost:11434

# --- Wake word ---------------------------------------------------------------
# Engine: openwakeword | porcupine | whisper
ASSISTANT_WAKEWORD_ENGINE=whisper

# whisper engine (no account/key): the phrase to listen for
ASSISTANT_WAKE_PHRASE=hey guru
# ASSISTANT_WAKE_WINDOW_SECONDS=1.6
# ASSISTANT_WAKE_CHECK_SECONDS=0.8

# openwakeword engine: built-in phrase (hey_jarvis | alexa | hey_mycroft | ...)
# ASSISTANT_WAKEWORD=hey_jarvis
# ASSISTANT_WAKEWORD_THRESHOLD=0.5

# porcupine engine: free key from console.picovoice.ai + your .ppn file
# ASSISTANT_PORCUPINE_KEY=
# ASSISTANT_PORCUPINE_KEYWORD=voice_assistant/hey-guru.ppn

# --- Transcription -----------------------------------------------------------
# ASSISTANT_WHISPER_MODEL=base.en        # tiny.en (faster) ... small.en (better)

# --- Reminders / notifications -----------------------------------------------
# ASSISTANT_ANNOUNCE_SCHEDULED=1         # 0 = stay silent until the reminder fires
# ASSISTANT_ENABLE_IMESSAGE=0            # 1 = also text yourself when a reminder fires
# ASSISTANT_IMESSAGE_HANDLE=+15551234567 # your phone/email for self-reminders

# --- Email -------------------------------------------------------------------
# ASSISTANT_EMAIL_REQUIRE_CONFIRM=1      # keep 1 — confirm before any send
# ASSISTANT_CONTACT_THRESHOLD=0.6
